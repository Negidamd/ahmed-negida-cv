# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real keys.

# Supabase project (find these in Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key_here
VITE_SUPABASE_PROJECT_ID=your_project_ref_here

# Mapbox (only if you use the RoadmapMapSection — find at https://account.mapbox.com)
# VITE_MAPBOX_TOKEN=your_public_mapbox_token_here
